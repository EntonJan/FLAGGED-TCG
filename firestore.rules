rules_version = '2';

// HINWEIS: Diese Datei wird NICHT automatisch angewendet.
// Firebase Console -> Firestore Database -> Rules -> Inhalt ersetzen -> Publish
//
// Update: Schreibzugriff auf die "cards"-Collection ist jetzt auf die
// Admin-E-Mail-Adresse beschraenkt (serverseitige Absicherung, nicht nur
// UI-Ausblenden).

service cloud.firestore {
  match /databases/{database}/documents {

    match /cards/{cardId} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == 'jdenkelmann@gmail.com';
    }

    match /decks/{deckId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.auth.uid == request.resource.data.ownerId;
      allow update, delete: if request.auth != null
                    && request.auth.uid == resource.data.ownerId;
    }

    // Live-Partien: Jeder eingeloggte Nutzer darf lesen (fuer Zuschauer/
    // Reconnect) und Zuege schreiben. v1-Vereinfachung: keine serverseitige
    // Pruefung, ob der Schreibende wirklich am Zug ist -- das uebernimmt
    // aktuell nur der Client (matchState.js). Fuer eine oeffentliche/
    // wettkampftaugliche Version sollte das spaeter per Cloud Function
    // serverseitig abgesichert werden.
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
    }
  }
}
